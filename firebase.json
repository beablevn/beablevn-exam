{
  "hosting": [
    {
      "site": "beablevn-ielts",
      "redirects": [
        {
          "source": "**",
          "destination": "https://beablevn-exam.web.app",
          "type": 301
        }
      ]
    },
    {
      "site": "beablevn-exam",
      "public": "dist",
      "ignore": [
        "firebase.json",
        "**/.*",
        "**/node_modules/**"
      ],
      "rewrites": [
        {
          "source": "**",
          "destination": "/index.html"
        }
      ],
      "headers": [
        {
          "source": "/index.html",
          "headers": [
            {
              "key": "Cache-Control",
              "value": "no-cache, no-store, must-revalidate"
            }
          ]
        },
        {
          "source": "/sw.js",
          "headers": [
            {
              "key": "Cache-Control",
              "value": "no-cache, no-store, must-revalidate"
            }
          ]
        }
      ]
    }
  ],
  "functions": {
    "source": "functions"
  },
  "database": {
    "rules": "database.rules.json"
  }
}